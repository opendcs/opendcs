<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee"
         xmlns:xsi="http://w3.org"
         xsi:schemaLocation="https://jakarta.ee 
                             https://jakarta.ee/web-app_6_0.xsd"
         version="6.0">

    <display-name>OpenDCS Web UI</display-name>

    <!-- Defines the first page a user sees when visiting the root URL -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <error-page>
        <error-code>404</error-code>
        <location>/index.html</location>
    </error-page>
</web-app>